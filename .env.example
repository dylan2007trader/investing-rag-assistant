# Copy to .env and fill in. All values are optional — the app runs without them.

# Enables fully generated, cited answers (otherwise "demo mode" returns top passage)
ANTHROPIC_API_KEY=

# Optional model override
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Embedding backend: auto | st | tfidf
#   auto  -> use sentence-transformers if installed, else TF-IDF
#   st    -> force sentence-transformers (semantic)
#   tfidf -> force TF-IDF (zero download)
EMBED_BACKEND=auto
